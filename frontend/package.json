{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "capture": "ts-node --esm scripts/capture/capture.ts",
    "capture:clean": "ts-node --esm scripts/capture/capture.ts --mode=all --cleanup=clean --audit",
    "capture:archive": "ts-node --esm scripts/capture/capture.ts --mode=all --cleanup=archive --audit",
    "capture:fresh": "npm run capture:clean && npm run visual:diff",
    "capture:desktop": "ts-node --esm scripts/capture/capture.ts --mode=desktop",
    "capture:tablet": "ts-node --esm scripts/capture/capture.ts --mode=tablet",
    "capture:mobile": "ts-node --esm scripts/capture/capture.ts --mode=mobile",
    "capture:all": "ts-node --esm scripts/capture/capture.ts --mode=all",
    "audit": "ts-node --esm scripts/capture/capture.ts --mode=desktop --audit",
    "capture:multi": "node scripts/capture/run-capture-multi.js",
    "diff:multi": "node scripts/capture/diff-multi.js",
    "baseline:generate": "ts-node --esm scripts/capture/baseline.ts --generate",
    "baseline:compare": "ts-node --esm scripts/capture/baseline.ts --compare",
    "baseline:approve": "ts-node --esm scripts/capture/baseline.ts --approve",
    "visual:diff": "ts-node --esm scripts/capture/diff.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lighthouse": "^13.3.0",
    "playwright": "^1.60.0",
    "ts-node": "^10.9.1",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.3.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
